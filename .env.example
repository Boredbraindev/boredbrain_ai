# =============================================================================
# BoredBrain AI - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# All variables are optional unless marked [REQUIRED].
# =============================================================================

# -----------------------------------------------------------------------------
# Core [REQUIRED]
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/boredbrain
BETTER_AUTH_SECRET=generate-a-random-secret-here

# -----------------------------------------------------------------------------
# AI Providers (at least one recommended)
# -----------------------------------------------------------------------------
XAI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
DAYTONA_API_KEY=

# -----------------------------------------------------------------------------
# Database Replicas (optional, for read scaling)
# -----------------------------------------------------------------------------
READ_DB_1=
READ_DB_2=

# -----------------------------------------------------------------------------
# OAuth Providers (optional, for social login)
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Redis / Cache (optional)
# -----------------------------------------------------------------------------
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Tool API Keys (optional, enables specific tools)
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=
VALYU_API_KEY=
TMDB_API_KEY=
YT_ENDPOINT=
FIRECRAWL_API_KEY=
PARALLEL_API_KEY=
OPENWEATHER_API_KEY=
GOOGLE_MAPS_API_KEY=
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
ALCHEMY_API_KEY=
SMITHERY_API_KEY=
COINGECKO_API_KEY=
SUPERMEMORY_API_KEY=

# -----------------------------------------------------------------------------
# Infrastructure (optional)
# -----------------------------------------------------------------------------
CRON_SECRET=
BLOB_READ_WRITE_TOKEN=
QSTASH_TOKEN=
RESEND_API_KEY=
ALLOWED_ORIGINS=http://localhost:3009

# -----------------------------------------------------------------------------
# Polar Payment Integration (optional)
# -----------------------------------------------------------------------------
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRO_PRODUCT_ID=
POLAR_SUCCESS_URL=/settings?checkout=success
POLAR_PORTAL_RETURN_URL=/settings
POLAR_SANDBOX=false
