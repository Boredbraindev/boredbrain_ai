{
  "functions": {
    "app/api/**/*.ts": {
      "memory": 256,
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/agents/heartbeat",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/topics/participate",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/topics/collect",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/qc",
      "schedule": "0 */6 * * *"
    }
  ]
}
