# BoredBrain Docker Environment
# Copy this to .env.docker and fill in real values

# ---- Database (Docker internal) ----
DATABASE_URL=postgresql://bbai:bbai_secret_2024@postgres:5432/boredbrain
USE_LOCAL_DB=1
REDIS_URL=redis://redis:6379

# ---- Auth ----
BETTER_AUTH_SECRET=change-this-to-a-real-secret-in-production
BETTER_AUTH_URL=http://localhost:3000

# ---- OAuth (replace with real values) ----
GITHUB_CLIENT_ID=dummy
GITHUB_CLIENT_SECRET=dummy
GOOGLE_CLIENT_ID=dummy
GOOGLE_CLIENT_SECRET=dummy
TWITTER_CLIENT_ID=dummy
TWITTER_CLIENT_SECRET=dummy

# ---- AI API Keys (replace with real values) ----
XAI_API_KEY=dummy
OPENAI_API_KEY=dummy
ANTHROPIC_API_KEY=dummy
GROQ_API_KEY=dummy
